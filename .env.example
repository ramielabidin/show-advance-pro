# Supabase
# Get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Edge function secrets (NOT client env — set via `supabase secrets set`)
# ---------------------------------------------------------------------------
# Listed here as documentation only. These never ship in the client bundle;
# they must be configured on the Supabase project for the relevant edge
# functions to work.
#
# send-daysheet-email:
#   SENDGRID_API_KEY      — SendGrid API key with "Mail Send" scope.
#   SENDGRID_FROM_EMAIL   — Verified sender address (e.g. daysheets@yourdomain).
