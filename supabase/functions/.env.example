# Server-side secrets for Supabase Edge Functions.
#
# This file is DOCUMENTATION ONLY. Nothing loads these values at runtime —
# they must be configured in the Supabase Dashboard:
#   Project Settings → Edge Functions → Secrets
#
# Never prefix any of these with VITE_. VITE_ variables are bundled into the
# browser build and are effectively public.
#
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# auto-injected by Supabase into every function. You do not set them yourself.

# --- Anthropic (parse-advance) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Places
# (autocomplete-place, calculate-drive-time, lookup-venue-address) ---
GOOGLE_PLACES_API_KEY=AIza...

# --- Slack OAuth (slack-oauth-initiate, slack-oauth-callback) ---
SLACK_CLIENT_ID=1234567890.1234567890
SLACK_CLIENT_SECRET=...
# Random high-entropy string used to HMAC-sign the OAuth `state` param.
SLACK_STATE_SECRET=...

# --- Misc (slack-oauth-callback) ---
# Public origin the OAuth callback redirects users back to. Falls back to
# http://localhost:5173 if unset, which is fine for local dev but should be
# set explicitly in the hosted project.
APP_URL=https://advancetouring.com
